{
  "commitMessage": "Obsidian commit {{date}}",
  "commitDateFormat": "YYYY-MM-DD HH:mm:ss",
  "autoSaveInterval": 0,
  "autoPushInterval": 0,
  "autoPullInterval": 5,
  "pullOptions": ["default", "hard", "soft", "index"],
  "pushOptions": ["force", "force-with-lease", "force-with-lease-oss", "no-force", "force-with-lease-if-updates"],
  "autosaveIntervalSeconds": 0,
  "differentIntervalForSaveAndPush": false,
  "autoPullOnBoot": true,
  "autoPushOnChatComplete": false,
  "autoPushOnMarkdownChange": true,
  "autoPushOnRegularChange": true,
  "commitMessageOfMerges": "Merge {{current}} into {{destination}}",
  "ignore": [
    ".obsidian/plugins/",
    ".obsidian/workspace.json"
  ]
}
